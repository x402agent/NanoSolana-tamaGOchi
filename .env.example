# ── NanoSolana :: Environment Variables ───────────────────────────────────────
# Copy this to .env and fill in your values.
#
#   cp .env.example .env
#
# REQUIRED for trading: Helius RPC/API/WSS, Birdeye API/WSS, Jupiter API
# NanoSolana degrades gracefully when optional services are unavailable.
# ──────────────────────────────────────────────────────────────────────

# ── Helius (Solana RPC + WebSocket) ──────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_NETWORK=mainnet
HELIUS_TIMEOUT=20
HELIUS_RETRIES=3

# ── Birdeye (Market Data + Analytics) ────────────────────────────────
BIRDEYE_API_KEY=
BIRDEYE_WSS_URL=

# ── Jupiter (DEX Aggregator) ─────────────────────────────────────────
JUPITER_API_KEY=
JUPITER_ENDPOINT=https://api.jup.ag

# ── Aster (Perp DEX) ─────────────────────────────────────────────────
ASTER_API_KEY=
ASTER_API_SECRET=

# ── Solana Wallet ───────────────────────────────────────────────────────
# If not set, NanoSolana auto-generates a wallet at ~/.nanosolana/wallet/
# The agent wallet is created at first boot with its heartbeat.
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_PUBKEY=

# ── LLM Providers ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/healer-alpha
ANTHROPIC_API_KEY=

# ── Supabase (Persistent Memory) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=
TELEGRAM_PROXY=
TELEGRAM_API_BASE=

# ── x402 Payment Protocol ────────────────────────────────────────────
# Multi-chain crypto payments for NanoSolana API endpoints
X402_ENABLED=true
X402_FACILITATOR_URL=https://facilitator.x402.rs
X402_FACILITATOR_AUTHORIZATION=
X402_RECIPIENT_ADDRESS=
X402_PAYMENT_AMOUNT=0.001
X402_NETWORK=solana
X402_CHAINS=solana
X402_PAYWALL_ENABLED=false
X402_PAYWALL_PORT=18402
X402_PROXY_ENABLED=true
X402_PROXY_PORT=18403

# ── Headless Node Client ─────────────────────────────────────────────
# Configuration for the NanoSolana headless bridge client (hardware nodes)
NODE_BRIDGE_ADDR=127.0.0.1:18790
NODE_DISPLAY_NAME=
NODE_DEVICE_FAMILY=
NODE_SESSION_KEY=main
NODE_TTS_ENGINE=none

# ── NanoSolana Gateway Spawn ─────────────────────────────────────────
# Auto-spawn NanoSolana native gateway in tmux with Tailscale mesh networking
GATEWAY_AUTO_SPAWN=false
GATEWAY_SPAWN_PORT=18790
GATEWAY_USE_TAILSCALE=true
