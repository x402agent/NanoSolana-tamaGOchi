# ── MawdBot Go :: Environment Variables ───────────────────────────────
# Copy this to .env and fill in your values.
#
#   cp .env.example .env
#
# All keys are optional — MawdBot degrades gracefully when services
# are unavailable.
# ──────────────────────────────────────────────────────────────────────

# ── Helius (Solana RPC + WebSocket) ──────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_NETWORK=mainnet
HELIUS_TIMEOUT=20
HELIUS_RETRIES=3

# ── Birdeye (Market Data + Analytics) ────────────────────────────────
BIRDEYE_API_KEY=
BIRDEYE_WSS_URL=

# ── Jupiter (DEX Aggregator) ─────────────────────────────────────────
JUPITER_API_KEY=
JUPITER_ENDPOINT=https://api.jup.ag

# ── Aster (Perp DEX) ─────────────────────────────────────────────────
ASTER_API_KEY=
ASTER_API_SECRET=

# ── Solana Wallet ─────────────────────────────────────────────────────
# If not set, MawdBot auto-generates a wallet at ~/.mawdbot/wallet/
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_PUBKEY=

# ── LLM Providers ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase (Persistent Memory) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=
TELEGRAM_PROXY=
TELEGRAM_API_BASE=

# ── x402 Payment Protocol ────────────────────────────────────────────
# Multi-chain crypto payments for MawdBot API endpoints
X402_FACILITATOR_URL=https://facilitator.x402.rs
X402_RECIPIENT_ADDRESS=
X402_PAYMENT_AMOUNT=0.001
X402_NETWORK=solana
X402_CHAINS=solana
X402_PAYWALL_ENABLED=false
