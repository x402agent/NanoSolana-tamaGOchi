# NanoSolana .env.example
# Copy to `.env` (local dev) or `~/.nanosolana/.env` (daemon mode)
# Precedence: process env → ./.env → ~/.nanosolana/.env → nanosolana.json `env` block
#
# For the full nano-core env template, see: nano-core/nanoclaw-main/.env.example

# ── Gateway ─────────────────────────────────────────────
NANO_GATEWAY_TOKEN=change-me-to-a-long-random-token
# NANO_GATEWAY_PASSWORD=change-me-to-a-strong-password

# ── NanoSolana State ────────────────────────────────────
# NANOSOLANA_STATE_DIR=~/.nanosolana
# NANOSOLANA_CONFIG_PATH=~/.nanosolana/nanosolana.json

# ── AI Provider (OpenRouter — primary) ─────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/healer-alpha

# ── AI Provider (Alternatives) ─────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key
# GEMINI_API_KEY=your-gemini-key
# XAI_API_KEY=your-xai-key

# ── Solana Infrastructure ──────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your-helius-api-key
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Market Data ────────────────────────────────────────
BIRDEYE_API_KEY=your-birdeye-api-key
BIRDEYE_WSS_URL=wss://public-api.birdeye.so/socket

# ── Trading (Jupiter) ─────────────────────────────────
JUPITER_API_KEY=your-jupiter-api-key
JUPITER_REFERRAL=your-referral-address

# ── Wallet & Auth ──────────────────────────────────────
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_APP_SECRET=your-privy-app-secret
# THIRDWEB_CLIENT_ID=your-thirdweb-client-id

# ── Databases (optional) ──────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_URL=https://your-project.supabase.co
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
# REDIS_URL=redis://default:password@host:port

# ── Cloud Services (optional) ─────────────────────────
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# PINATA_JWT=your-pinata-jwt
# E2B_API_KEY=your-e2b-key
# STEEL_API_KEY=your-steel-key

# ── Communication Channels (optional) ─────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_USERS=user1,user2

# ── Financial Data (optional) ─────────────────────────
# FINANCIAL_DATASET_API_KEY=your-financial-datasets-key

# ── Voice (optional) ──────────────────────────────────
# ELEVEN_LABS_API_KEY=your-elevenlabs-key
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-livekit-key
