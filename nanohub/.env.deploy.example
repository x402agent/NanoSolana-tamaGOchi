# Required for Convex production deploy
CONVEX_DEPLOY_KEY=
CONVEX_SITE_URL=

# Required for web build/runtime wiring
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
SITE_URL=

# Optional Supabase event mirroring (for publish/highlight events)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVENTS_TABLE=skill_events

# Optional: defaults to current git short SHA when omitted
VITE_APP_BUILD_SHA=

# Optional: needed for fully non-interactive Vercel deploys
VERCEL_TOKEN=