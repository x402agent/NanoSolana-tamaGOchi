{
  "id": "telegram",
  "name": "Telegram",
  "description": "NanoSolana Telegram channel with persistent conversation memory",
  "channels": ["telegram"],
  "persistence": {
    "enabled": true,
    "dbPath": "~/.nanosolana/telegram",
    "conversationHistory": true,
    "maxHistoryPerChat": 200,
    "summaryThreshold": 50
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "botToken": { "type": "string", "description": "Telegram bot token" },
      "persistence": { "type": "boolean", "default": true, "description": "Enable conversation persistence" }
    }
  }
}
