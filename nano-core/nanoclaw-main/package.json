{
  "name": "@nanosolana/core",
  "version": "2.0.0",
  "description": "NanoSolana core runtime — autonomous financial agents on Solana with OODA trading loop, ClawVault memory, and mesh networking",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/x402agent/NanoSolana.git",
    "directory": "nano-core/nanoclaw-main"
  },
  "keywords": [
    "nanosolana",
    "solana",
    "agent",
    "trading",
    "defi",
    "ai",
    "autonomous",
    "financial",
    "ooda",
    "web3"
  ],
  "author": "NanoSolana Labs",
  "license": "MIT"
}
