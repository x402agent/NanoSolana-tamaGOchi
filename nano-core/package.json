{
  "name": "nanosolana",
  "version": "1.0.0",
  "description": "🦞 The open-source agentic framework for financial intelligence on Solana. Autonomous OODA trading, epistemological memory, mesh coordination, and a virtual pet soul — deploy in 30 seconds.",
  "keywords": [
    "solana",
    "trading-bot",
    "ai-agent",
    "defi",
    "autonomous-agent",
    "financial-intelligence",
    "ooda",
    "jupiter",
    "helius",
    "birdeye",
    "web3",
    "crypto",
    "nft",
    "memecoin",
    "blockchain",
    "wallet",
    "solana-agent",
    "trading-strategy",
    "rsi",
    "ema",
    "market-maker",
    "cli",
    "sdk",
    "tamagotchi",
    "mesh-network",
    "openrouter",
    "metaplex",
    "swap",
    "dex",
    "agentic-framework"
  ],
  "license": "MIT",
  "author": "NanoSolana Labs <team@nanosolana.com> (https://nanosolana.com)",
  "homepage": "https://nanosolana.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x402agent/NanoSolana.git",
    "directory": "nano-core"
  },
  "bugs": {
    "url": "https://github.com/x402agent/NanoSolana/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/x402agent"
    }
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "bin": {
    "nanosolana": "dist/cli/entry.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "tsx watch src/cli/entry.ts",
    "build": "tsup src/index.ts src/cli/entry.ts --format esm --dts --sourcemap --out-dir dist --clean",
    "start": "node dist/cli/entry.js",
    "demo": "tsx src/cli/entry.ts demo",
    "install:one-shot": "bash scripts/install-cli.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --type-aware",
    "format": "oxfmt --write",
    "gateway": "tsx src/gateway/server.ts",
    "hub:dev": "cd ../nanohub && bun run dev",
    "nanosolana": "tsx src/cli/entry.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.3.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^11.0.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36.0",
    "eventemitter3": "^5.0.0",
    "express": "^5.2.1",
    "hono": "^4.12.7",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tweetnacl": "^1.0.3",
    "undici": "^7.22.0",
    "unicode-animations": "^1.0.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "oxfmt": "0.38.0",
    "oxlint": "^1.53.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}