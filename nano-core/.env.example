# ╔══════════════════════════════════════════════════════════════╗
# ║        NanoSolana TamaGObot — Environment Configuration    ║
# ║   By NanoSolana Labs                                        ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Quick start:
# 1) Copy to `.env` in the nano-core directory
# 2) Fill in your API keys
# 3) Run `nano init` for encrypted vault storage
#
# NOTE: Keys set here are loaded at startup. For maximum security,
# use `nano init` to store them in the AES-256-GCM encrypted vault
# at ~/.nanosolana/vault.enc instead of keeping them in .env.

# ─── Agent Identity ──────────────────────────────────────────
NANO_AGENT_NAME=NanoSolana

# ─── OpenRouter AI (Primary LLM Provider) ────────────────────
# Model: openrouter/healer-alpha (multimodal)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/healer-alpha
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Helius (Solana RPC + WebSocket) ─────────────────────────
# Get your key at: https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your-helius-api-key
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ─── Birdeye (Token Analytics + Price Feeds) ─────────────────
# Get your key at: https://birdeye.so/developers
BIRDEYE_API_KEY=your-birdeye-api-key
# BIRDEYE_WSS_URL=wss://public-api.birdeye.so/socket

# ─── Jupiter (DEX Swap Aggregator) ───────────────────────────
# Get your key at: https://station.jup.ag
JUPITER_API_KEY=your-jupiter-api-key

# ─── Solana Wallet ────────────────────────────────────────────
# Auto-generated on `nano birth` if not set.
# Use existing wallet (base58 private key):
# SOLANA_PRIVATE_KEY=your-base58-private-key

# ─── Gateway ─────────────────────────────────────────────────
NANO_GATEWAY_PORT=18790
# NANO_GATEWAY_HOST=0.0.0.0
# NANO_GATEWAY_SECRET=your-hmac-secret

# ─── Nano Hub ────────────────────────────────────────────────
# NANO_HUB_URL=http://localhost:3000
# NANO_HUB_API_KEY=your-hub-api-key

# ─── Tailscale (Mesh Networking) ─────────────────────────────
# TAILSCALE_AUTH_KEY=tskey-auth-...
# TAILSCALE_DOMAIN=your-tailnet.ts.net

# ─── Memory ──────────────────────────────────────────────────
# NANO_MEMORY_DB_PATH=~/.nanosolana/memory.db
# NANO_MEMORY_TEMPORAL_DECAY_HOURS=168

# ─── Vault ───────────────────────────────────────────────────
# NANO_VAULT_PASSWORD=your-custom-vault-password

# ─── Legacy/Alternative AI Providers ─────────────────────────
# AI_PROVIDER=openrouter
# AI_API_KEY=your-api-key
# AI_MODEL=openrouter/healer-alpha
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Logging ─────────────────────────────────────────────────
NANO_LOG_LEVEL=info
